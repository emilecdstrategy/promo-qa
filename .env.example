# Asana OAuth app (webhooks / OAuth flow)
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# Asana MCP OAuth app (if using Asana MCP server)
ASANA_MCP_CLIENT_ID=
ASANA_MCP_CLIENT_SECRET=

# Required to read tasks via API — create at:
# https://app.asana.com/0/my-apps → Personal access tokens
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_GID=1201007545370748
ASANA_ASSIGNEE_GID=1206406200377321

# Theme Access passwords (one per store) — from Apps → Theme Access on each store
# SHOPIFY_THEME_ACCESS__STORE_SLUG=shptka_...
# SHOPIFY_STORE__STORE_SLUG=store-slug.myshopify.com
# SHOPIFY_LIVE_THEME__STORE_SLUG=123456789

# Supabase project and function
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Generate a long random value and never rotate it without re-encrypting store tokens.
STORE_TOKEN_ENCRYPTION_KEY=
# Optional override for local/deployed function endpoint
SUPABASE_FUNCTION_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
QA_CONFIDENCE_THRESHOLD=0.85

# SMTP alerts for unregistered stores and processing errors
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_EMAIL_TO=
